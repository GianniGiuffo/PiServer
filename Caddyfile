{
	# Cloudflare provides public HTTPS. Caddy receives private HTTP only from the
	# cloudflared container, so it must not attempt ACME certificates or redirects.
	auto_https off
}

http://{$SITE_1_DOMAIN} {
	encode zstd gzip
	root * /srv/sites/site-1/current

	# The public section entry explains how to connect through Tailscale. Actual
	# private documents remain unavailable through the public domain.
	@private_entry path /private /private/ /en/private /en/private/
	handle @private_entry {
		redir /accesso-privato/ 302
	}
	@private_site path /private/* /en/private/*
	handle @private_site {
		respond 404
	}
	handle {
		file_server
	}
	header -Server
}

# This listener is mapped only to the host loopback address. Tailscale Serve
# exposes it on a dedicated tailnet-only HTTPS port; Cloudflare never reaches it.
http://:8083 {
	encode zstd gzip
	root * /srv/sites/site-1/current
	file_server
	header -Server
}

http://{$SITE_2_DOMAIN} {
	encode zstd gzip
	root * /srv/sites/site-2/current
	file_server
	header -Server
}

http://{$VAULTWARDEN_DOMAIN} {
	encode zstd gzip
	reverse_proxy vaultwarden:80 {
		# The browser connected to Cloudflare with HTTPS; preserve that fact for
		# Vaultwarden even though the final Docker-network hop uses HTTP.
		header_up X-Forwarded-Proto https
	}
	header -Server
}

# n8n itself is declared only in compose.automation.yaml. These routes are
# inert on the Raspberry Pi because the default hostnames end in .invalid.
# On the mini PC, the editor and public webhooks intentionally use two
# different hostnames so Cloudflare Access can protect the editor without
# blocking third-party webhook calls.
(n8n_proxy) {
	encode zstd gzip
	reverse_proxy n8n:5678 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-For {remote_host}
	}
	header -Server
}

http://{$N8N_DOMAIN} {
	import n8n_proxy
}

http://{$N8N_WEBHOOK_DOMAIN} {
	import n8n_proxy
}
