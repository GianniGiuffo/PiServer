# Copy to .env on the Raspberry Pi and replace every value marked CHANGE_ME.
# Keep .env chmod 600 and OUT of Git.

TZ=Europe/Rome
ACME_EMAIL=CHANGE_ME@example.com

# Public DNS names. Their A/AAAA records must reach the Raspberry Pi.
SITE_1_DOMAIN=site-one.example.com
SITE_2_DOMAIN=site-two.example.com
VAULTWARDEN_DOMAIN=vault.example.com
# Keep true only for the very first account registration, then change to false
# and redeploy the Vaultwarden service.
VAULTWARDEN_SIGNUPS_ALLOWED=true

# The MagicDNS FQDN reported by: tailscale status --json | jq -r .Self.DNSName
# Remove the final dot, if present. It is used only by Nextcloud.
TAILSCALE_FQDN=raspberry.tailnet-name.ts.net

# Runtime directories. DATA_DIR and SITES_DIR should be on an SSD formatted ext4.
STACK_DIR=/opt/raspberry-server
DATA_DIR=/srv/raspberry-server/data
SITES_DIR=/srv/raspberry-server/sites
STAGING_DIR=/srv/raspberry-server/staging

# Use long, unique random values. Generate them with: openssl rand -base64 48
PIHOLE_PASSWORD=CHANGE_ME
NEXTCLOUD_DB_PASSWORD=CHANGE_ME
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME

# This value protects the optional Vaultwarden /admin page. It must be an Argon2 PHC
# hash, not a clear-text token. See docs/security.md.
# Keep the single quotes: an Argon2 hash begins with '$', which Compose would
# otherwise try to interpolate while reading this file.
VAULTWARDEN_ADMIN_TOKEN='CHANGE_ME'

# Pin every image to a digest before the first real deployment, then review updates
# in Git. Tags below make the initial setup readable, but are not an immutable lock.
CADDY_IMAGE=caddy:2-alpine
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
PIHOLE_IMAGE=pihole/pihole:latest
VAULTWARDEN_IMAGE=vaultwarden/server:latest
NEXTCLOUD_IMAGE=nextcloud:apache
POSTGRES_IMAGE=postgres:17-alpine
REDIS_IMAGE=redis:7-alpine

# Copy the token generated by Cloudflare Zero Trust for the `pi-server` tunnel.
# Keep the surrounding single quotes and never commit the real value.
CLOUDFLARE_TUNNEL_TOKEN='CHANGE_ME'
