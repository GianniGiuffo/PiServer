# The first public site: Hugo 0.163.3 plus Tailwind CSS 4.
# Copy to /etc/raspberry-server/sites/site-1.env. This repository is public,
# so the Pi clones it over HTTPS and needs no deploy key.
REPOSITORY=https://github.com/GianniGiuffo/PersonalWebsite.git
BRANCH=main
BUILD_IMAGE=raspberry-server/hugo-builder:0.163.3
BUILD_COMMAND='npm ci && HUGO_ENV=production HUGO_ENABLEGITINFO=true hugo build --gc --minify --baseURL https://tommasofrancescon.it/'
PUBLISH_DIR=public
