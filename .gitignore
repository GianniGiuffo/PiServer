# Runtime configuration and secrets: keep in a password manager, never in Git.
.env
secrets/

# Application state, media, databases, backups and transient site clones.
data/
sites/
# Keep site deployment templates in Git; only their runtime copies under
# /etc and the generated content under /srv stay outside the repository.
!config/
!config/sites/
!config/sites/*.env.example
backups/
staging/

# Local editor/OS files.
.DS_Store
Thumbs.db
