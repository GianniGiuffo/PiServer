[Unit]
Description=Pull, build and publish the two static websites
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
User=__RPI_USER__
Group=__RPI_GROUP__
WorkingDirectory=__REPO_DIR__
Environment=HOME=/home/__RPI_USER__
ExecStart=__REPO_DIR__/scripts/deploy-sites.sh
Nice=10
